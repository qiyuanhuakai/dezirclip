{
  "name": "tiez-app",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "build": "tsc && vite build",
    "i18n:check": "node scripts/i18n-check.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:safe": "TIEZ_DISABLE_LINUX_SERVICES=window_tracker,edge_docking,mouse_hotkey tauri dev",
    "tauri:build": "tauri build",
    "build:portable": "tauri build --no-bundle --features portable && powershell -NoProfile -Command \"$ErrorActionPreference='Stop'; $out='artifacts/portable'; New-Item -ItemType Directory -Force -Path $out | Out-Null; Get-ChildItem 'src-tauri/target/release' -Filter *.exe | Copy-Item -Destination $out -Force; Compress-Archive -Path (Join-Path $out '*') -DestinationPath (Join-Path $out 'tiez-portable.zip') -Force\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "framer-motion": "^12.25.0",
    "fuse.js": "^7.4.2",
    "lucide-react": "^0.562.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-select": "^5.10.2",
    "react-virtuoso": "^4.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@tauri-apps/cli": "2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/react-select": "^5.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.40.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  }
}
