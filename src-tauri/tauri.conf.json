{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DezirClip",
  "version": "0.0.9",
  "identifier": "io.github.qiyuanhuakai.dezirclip",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build && pnpm run tauri:prepare-sidecars",
    "frontendDist": "../dist/web"
  },
  "app": {
    "windows": [
      {
        "title": "DezirClip",
        "label": "main",
        "width": 352,
        "height": 380,
        "minWidth": 250,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "visible": false,
        "dragDropEnabled": true,
        "focusable": false
      },
      {
        "label": "quick-paste",
        "title": "",
        "url": "index.html?window=quick-paste",
        "width": 480,
        "height": 360,
        "resizable": false,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "focusable": true,
        "shadow": false
      },
      {
        "label": "region-select",
        "title": "",
        "url": "index.html?window=region-select",
        "width": 1920,
        "height": 1080,
        "fullscreen": true,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "focusable": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; video-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self';",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "$APPCONFIG/**",
          "C:/**",
          "D:/**",
          "E:/**"
        ]
      },
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main window capabilities",
          "windows": [
            "main",
            "compact-preview",
            "quick-paste",
            "region-select"
          ],
          "permissions": [
            "core:window:allow-start-dragging",
            "core:window:allow-hide",
            "core:window:allow-show",
            "core:window:allow-set-focus",
            "core:window:allow-is-visible",
            "core:window:allow-inner-size",
            "core:window:allow-inner-position",
            "core:window:allow-outer-position",
            "core:window:allow-scale-factor",
            "core:window:allow-set-size",
            "core:window:allow-set-position",
            "core:window:allow-set-always-on-top",
            "core:window:allow-current-monitor",
            "core:window:allow-cursor-position",
            "core:window:allow-create",
            "core:window:allow-get-all-windows",
            "core:webview:allow-create-webview-window",
            "core:window:allow-set-ignore-cursor-events",
            "core:window:allow-set-focusable",
            "core:event:allow-listen",
            "core:event:allow-unlisten",
            "core:event:allow-emit",
            "core:app:allow-version",
            "core:app:default",
            "dialog:allow-open",
            "dialog:default",
            {
              "identifier": "core:path:default",
              "allow": [
                {
                  "path": "$HOME/**"
                },
                {
                  "path": "C:/**"
                },
                {
                  "path": "D:/**"
                },
                {
                  "path": "E:/**"
                }
              ]
            },
            "opener:default",
            {
              "identifier": "opener:allow-open-url",
              "allow": [
                {
                  "url": "https://github.com/qiyuanhuakai/dezirclip/**"
                }
              ]
            },
            "window-state:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/dzc"
    ],
    "resources": [
      "../skills/dzc-cli"
    ],
    "targets": [
      "nsis",
      "deb",
      "appimage",
      "rpm"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "compression": "lzma",
        "installerHooks": "nsis/uninstall.nsh",
        "languages": [
          "English",
          "SimpChinese",
          "TradChinese"
        ],
        "displayLanguageSelector": true,
        "startMenuFolder": "DezirClip"
      }
    }
  }
}
